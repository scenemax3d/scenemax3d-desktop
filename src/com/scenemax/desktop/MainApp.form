<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.scenemax.desktop.MainApp">
  <grid id="27dc6" binding="mainPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="35" y="15" width="542" height="460"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="31bc8" binding="bottomPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="South"/>
        <properties/>
        <border type="none"/>
        <children/>
      </grid>
      <grid id="a72b1" binding="topPanel" layout-manager="GridLayoutManager" row-count="1" column-count="4" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="b2d9" class="javax.swing.JTextField" binding="txtNavUrl">
            <constraints>
              <grid row="0" column="3" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
            </constraints>
            <properties>
              <text value=""/>
            </properties>
          </component>
          <hspacer id="45dec">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="1" hsize-policy="6" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
          </hspacer>
          <component id="70723" class="javax.swing.JLabel">
            <constraints>
              <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="command:"/>
            </properties>
          </component>
        </children>
      </grid>
      <splitpane id="475c1" binding="mainSplitPane">
        <constraints border-constraint="Center"/>
        <properties>
          <dividerLocation value="532"/>
          <oneTouchExpandable value="true"/>
          <orientation value="1"/>
          <resizeWeight value="0.0"/>
        </properties>
        <border type="none"/>
        <children>
          <grid id="fa910" binding="editorHostPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints>
              <splitpane position="right"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children/>
          </grid>
          <grid id="b01ed" binding="leftPanel" layout-manager="GridLayoutManager" row-count="3" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <splitpane position="left"/>
            </constraints>
            <properties>
              <background color="-855310"/>
              <enabled value="true"/>
            </properties>
            <border type="none"/>
            <children>
              <grid id="ecf9f" binding="classroomPane" layout-manager="BorderLayout" hgap="0" vgap="0">
                <constraints>
                  <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="921c4" class="javax.swing.JButton" binding="btnAskQuestion">
                    <constraints border-constraint="Center"/>
                    <properties>
                      <enabled value="false"/>
                      <horizontalTextPosition value="0"/>
                      <icon value="images/raise_hand_72x72.png"/>
                      <text value="Not Connected"/>
                      <verticalAlignment value="0"/>
                      <verticalTextPosition value="3"/>
                    </properties>
                  </component>
                  <component id="2b08d" class="javax.swing.JButton" binding="btnCancelQuestion">
                    <constraints border-constraint="South"/>
                    <properties>
                      <enabled value="false"/>
                      <text value="Cancel Message"/>
                    </properties>
                  </component>
                  <component id="4a38f" class="javax.swing.JButton" binding="btnActiveQuestions">
                    <constraints border-constraint="North"/>
                    <properties>
                      <enabled value="true"/>
                      <icon value="images/question1_32x32.png"/>
                      <text value=""/>
                    </properties>
                  </component>
                </children>
              </grid>
              <component id="1a03c" class="javax.swing.JButton" binding="btnAnswers">
                <constraints>
                  <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <icon value="images/answer1_32x32.png"/>
                  <text value=""/>
                </properties>
              </component>
              <scrollpane id="aa769">
                <constraints>
                  <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="ff6e3" class="javax.swing.JTree" binding="tree1" default-binding="true">
                    <constraints/>
                    <properties/>
                  </component>
                </children>
              </scrollpane>
              <toolbar id="a1956" binding="mainToolbar">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="1" fill="1" indent="0" use-parent-layout="false">
                    <preferred-size width="-1" height="20"/>
                  </grid>
                </constraints>
                <properties>
                  <orientation value="1"/>
                </properties>
                <border type="none"/>
                <children/>
              </toolbar>
            </children>
          </grid>
        </children>
      </splitpane>
    </children>
  </grid>
</form>
