game_over = {

	if(game_status==GAME_STATE_OVER) {
		return
	}
	
	game_status=GAME_STATE_OVER // game over
	gameover.draw game_over3 : size (550,160) and pos(550,150)
 
  wait for camera_mode==CAMERA_MODE_DEFAULT
  camera_mode = CAMERA_MODE_SHAKE 
  do async 
	  cincam1=>cinematic.camera.cinematic1
	  cincam1.play : target (player1 forward 1 up 3), duration 10
	  camera_mode = CAMERA_MODE_DEFAULT
	  run set_camera_on_player
  end do

  
  
	player1.stunned1
  wait 1 second
  player1.fall_idle1 loop
  
	player2.look at (player1)   
  player2.BackFlip
  player2.Idle loop

	msg2.draw press_space_to_continue : pos (544,450)
	
  wait for key space to be pressed
  msg2.draw clear
	run restart_game
	
}

[game_status==GAME_STATE_OVER]
restart_game = {

  do async
    run tiger_roar(1.3) async
    player1.clear character mode
    player2.clear character mode
    player1.pos (39.4,-87,29)
		player2.pos (39.95,-86.5,16.5)
		player1.switch to character mode : gravity 60
    player2.switch to character mode : gravity 40
  end do
  msg.print ""
	msg2.print ""
  wait 1.5 second
  
	audio.play "scream1"
	player1.jumping
	player1.idle2 loop
	
	gameover.draw clear

	run game_start

}
	