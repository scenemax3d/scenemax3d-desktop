
set_camera_on_player = {
  if(camera_mode==CAMERA_MODE_DEFAULT) {
  	camera.attach stop
  } else if(camera_mode==CAMERA_MODE_ATTACH_PLAYER1) {
  	camera.attach to player1 : pos(0,1.5,-7) // and rotate(-15,0,0)
  }

}

var camera_rotate_angle = 45, camera_rotate_dir = 1

[is_camera_rotating==1 && camera_mode != CAMERA_MODE_CHASE_PLAYER1]
rotate_camera = {
	camera_rotate_angle = camera_rotate_angle + 0.5 * camera_rotate_dir
	if (camera_rotate_angle > 90 || camera_rotate_angle<0) {
		camera_rotate_dir=camera_rotate_dir*-1
	}
	sys.print camera_rotate_angle
	middleSphere.move to (player1 forward cam1) in cam_move_speed seconds async
	var rad = camera_rotate_angle * 3.14 / 180
	var x = middleSphere.x + cos(rad) * 15
	var z = middleSphere.z + sin(rad) * 15
	//camera.pos(x, middleSphere.y, z)
	//camera.look at (middleSphere)
	camera.move to(x, middleSphere.y, z) in cam_move_speed seconds looking at (middleSphere up cam5)
}
run rotate_camera every cam_move_speed seconds

[camera_mode==CAMERA_MODE_DEFAULT && is_camera_rotating==0]
ambient_camera = {

  var fight_dist = distance(player1, player2)

  // --- Dramatic zoom: crash in tight on close combat, sweep wide on far range ---
  var dynamic_side = cam3
  var dynamic_height = cam4
  if (fight_dist < 3) {
    // Very close — claustrophobic tight shot, low angle looking up at fighters
    dynamic_side = cam3 - 3.0
    dynamic_height = cam4 - 1.2
  } else if (fight_dist < 5) {
    // Close — slightly pulled in, neutral height
    dynamic_side = cam3 - 1.0
    dynamic_height = cam4
  } else if (fight_dist < 8) {
    // Mid — standard framing
    dynamic_side = cam3 + 1.5
    dynamic_height = cam4 + 0.4
  } else {
    // Far — dramatic wide low sweep, full cinematic widescreen feel
    dynamic_side = cam3 + 4.5
    dynamic_height = cam4 - 0.8
  }

  // --- Big slow breathing wave: ±0.6 units over a 4-tick cycle ---
  var breath_offset = 0
  if (counter % 4 == 0) {
    breath_offset = 0.6
  } else if (counter % 4 == 1) {
    breath_offset = 0.3
  } else if (counter % 4 == 2) {
    breath_offset = -0.6
  } else {
    breath_offset = -0.3
  }

  // --- Height surge on jump: camera rises dramatically with the fighter ---
  var jump_lift = 0
  if (player1.data.is_jumping == 1) {
    jump_lift = 1.8
  } else if (player2.data.is_jumping == 1) {
    jump_lift = 1.4
  }

  // --- Forward lean: anchor pushed toward opponent for cinematic framing ---
  var lean = cam1 + 1.2

  middleSphere.move to (player1 forward lean) in cam_move_speed seconds async

  if (cam_side==1) {
    camera.move to (player1 forward cam2 right dynamic_side up (dynamic_height + breath_offset + jump_lift)) in cam_move_speed seconds looking at (middleSphere up cam5)
  } else {
    camera.move to (player1 forward cam2 left dynamic_side up (dynamic_height + breath_offset + jump_lift)) in cam_move_speed seconds looking at (middleSphere up cam5)
  }

}
run ambient_camera every 0.1 seconds

[camera_mode==CAMERA_MODE_DEFAULT]
shake_the_world = {
	camera_mode=CAMERA_MODE_SHAKE
	//camera.chase stop
	do 2 times
   camera.move backward 0.03 in 0.051 seconds	
   camera.move forward 0.03 in 0.051 seconds
  end do
  camera_mode=CAMERA_MODE_DEFAULT
  run set_camera_on_player

}

[camera_mode==CAMERA_MODE_DEFAULT]
shake_the_world2 = {
	camera_mode=CAMERA_MODE_SHAKE
	//camera.chase stop
	do 2 times
   camera.roll left 3 in 0.071 seconds	
   camera.roll right 5 in 0.051 seconds
   camera.roll left 2 in 0.051 seconds	
  end do
  camera_mode=CAMERA_MODE_DEFAULT
  run set_camera_on_player

}

