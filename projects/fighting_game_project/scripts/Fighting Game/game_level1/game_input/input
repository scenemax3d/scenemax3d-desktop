	do
	  player1.mma_kick1 at speed of 2.5 async
	  wait 0.5 seconds
	  player1.move forward 0.3 for 0.2 seconds async
	  [player1.data.is_jumping==0]
	  do
	    player1.flying_kick at speed of 2
	  end do
	end do
	action=PLAYER_ACTION_IDLE		
  
end do

