
[@allow_move]
when key W is pressed once do 
  
    laser_effect => effects.effekseer.Homing_Laser01_3//Laser02_3
    laser_effect.play pos (player1)
    
  audio.play "jump1"
  player1.data.is_jumping = 1
  do async
    camera_mode = CAMERA_MODE_CHASE_PLAYER1
    camera.chase player1
		wait 1 seconds
		camera.chase stop
		camera_mode = CAMERA_MODE_DEFAULT
		run set_camera_on_player
  end do
  
  do async
		player1.big_jump : protected
		player1.idle2 loop
		player1.look at (player2)
		player1.data.is_jumping = 0
  end do

  do async
	  wait 1 seconds
	  audio.play "crash1"
		wait 0.1 second
		run shake_the_world2
		//
	end do
	
  player1.move forward 0.5 for 0.5 seconds async
  player1.character.jump at speed of 35
  
end do


