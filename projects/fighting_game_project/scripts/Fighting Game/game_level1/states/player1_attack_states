var player2_head_hit_cnt = 0

player2_head_hit = {
  
  score = score + 10;
  run popup_msg ("+10") async
	life2 = life2 - 1
	player2_head_hit_cnt = player2_head_hit_cnt + 1
	if (player2_head_hit_cnt % 3 == 0) {
		do async
		  player2.shader = "dramatic_hit_red"
			player2_hit1.pos(player2."mixamorig:Head") 
			player2_hit1.show
			player2_hit1.play (frame 0 to 15) 
			player2_hit1.hide
			player2.shader = ""
		end do
		audio.play "hurt1"
	}
	audio.play "punch1"
	player2."Hit" async
	run shake_the_world async
	player2.move backward 0.4 for 0.2 seconds
}

when @hit_by_legs && action == PLAYER_ACTION_S && player1.anim_percent < 25 do
  do async
		
	  run ambient_camera
		perfect => perfect1 sprite : scale 3, billboard true, pos(player1."mixamorig:Head"), collision shape none
	  wait 0.2 seconds
	  perfect.move forward 5 in 0.5 seconds
	  perfect.delete
  end do

  audio.play "attack1_jap"
  run player1_slow_motion (0.5,40)

end do

when player1.data.attack_legs == 1 do
  
  audio.play "jump1"
  do async
		wait 0.3 seconds
		action=PLAYER_ACTION_IDLE
		player1.data.attack_legs = 0
  end do
  action=PLAYER_ACTION_C
	player1.look at (player2)
  player1.move forward 0.3 for 0.5 seconds async
	player1.leg_takedown_attacker at speed of 2.5
  wait 0.3 seconds

  [player1.data.takedown_punches==0]
  player1.idle2 loop
  wait 0.5 seconds
end do

when @player1_grabs_for_takedown_player2 do
	audio.play "punch1"
	audio.play "hurt1"
	player2.data.is_down=1
	do async
	  player2_hit2.pos(player2."mixamorig:Head") 
		player2_hit2.show
		player2_hit2.play (frame 0 to 15) 
		player2_hit2.hide
	end do

	//run flash_hit_text async
	player2.leg_takedown_victim at speed of 2
	player2.data.is_down=0
	player1.data.hand_attack_hit = 0
	sys.print ""
end do

when @player1_grabs_for_throwing_player2 do
		player2.data.trapped = 1
		player2.clear character mode
		player2.look at (player1)
		player2.move to (player1 forward 4) in 0.5 second async
		audio.play "hurt1"
		player2.pull_start at speed of 3
end do

when @player1_hand_attack_head do
	run player2_head_hit 
  player1.data.hand_attack_hit = 0
  player2.data.head_hit = 0
end do

when @player1_can_hit && player1.data.foot_attack_hit == 1 && player2.data.head_hit == 1 do
	run player2_head_hit 
  player1.data.foot_attack_hit = 0
  player2.data.head_hit = 0
  
end do

when @player1_hand_attack_body do
	run player2_head_hit 
  player1.data.hand_attack_hit = 0
  player2.data.body_hit = 0
  
end do

when @player1_can_hit && player1.data.foot_attack_hit == 1 && player2.data.body_hit == 1 do
	run player2_head_hit 
  player1.data.foot_attack_hit = 0
  player2.data.body_hit = 0
end do
